          <Link
            to="/register"
            style={{
              background: "var(--ink)",
              color: "#fff",
              padding: "0.5rem 1.2rem",
              borderRadius: "4px",
              textDecoration: "none",
              fontSize: "0.9rem",
              fontWeight: 500,
            }}
          >
            Get Started
