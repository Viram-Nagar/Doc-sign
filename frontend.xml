              style={{
                fontFamily: "Fraunces, serif",
                fontSize: "1.8rem",
                fontWeight: 700,
                color: s.color,
                lineHeight: 1,
                marginBottom: "3px",
              }}
            >
              <AnimatedNumber target={counts[s.key]} />
            </div>
            <div
              style={{
                fontSize: "0.72rem",
                fontWeight: 700,
                textTransform: "uppercase",
                letterSpacing: "0.07em",
                color: "var(--muted)",
